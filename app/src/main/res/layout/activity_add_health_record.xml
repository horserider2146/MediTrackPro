<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:text="← Back"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:text="📋 Add Health Record"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Manually log a health record"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Record Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:letterSpacing="0.12"
            android:text="RECORD TYPE"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button android:id="@+id/btnTypeLab" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:backgroundTint="@color/accent" android:text="🧪 Lab" android:textColor="@color/bg_dark" android:textSize="11sp" android:textStyle="bold"/>
            <Button android:id="@+id/btnTypePrescription" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:layout_marginStart="4dp" android:backgroundTint="@color/surface" android:text="📋 Prescription" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button android:id="@+id/btnTypeDoctorVisit" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:backgroundTint="@color/surface" android:text="🏥 Doctor Visit" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold"/>
            <Button android:id="@+id/btnTypeVaccination" android:layout_width="0dp" android:layout_height="38dp" android:layout_weight="1" android:layout_marginStart="4dp" android:backgroundTint="@color/surface" android:text="💉 Vaccination" android:textColor="@color/text_secondary" android:textSize="11sp" android:textStyle="bold"/>

        </LinearLayout>

        <!-- Fields -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="Title / Test Name" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                    <EditText android:id="@+id/etRecordTitle" android:layout_width="match_parent" android:layout_height="52dp" android:background="@null" android:hint="e.g. Blood CBC Panel, Flu Shot" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                </androidx.cardview.widget.CardView>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="Doctor Name (optional)" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                    <EditText android:id="@+id/etDoctorName" android:layout_width="match_parent" android:layout_height="52dp" android:background="@null" android:hint="e.g. Dr. Sharma" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                </androidx.cardview.widget.CardView>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="Status" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                    <EditText android:id="@+id/etStatus" android:layout_width="match_parent" android:layout_height="52dp" android:background="@null" android:hint="e.g. Normal, Active, Done" android:paddingStart="16dp" android:paddingEnd="16dp" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                </androidx.cardview.widget.CardView>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="Notes (optional)" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                    <EditText android:id="@+id/etNotes" android:layout_width="match_parent" android:layout_height="80dp" android:background="@null" android:hint="Additional notes..." android:gravity="top" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="12dp" android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary" android:textSize="14sp"/>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnSaveRecord"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/accent"
            android:text="Save Record"
            android:textColor="@color/bg_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>