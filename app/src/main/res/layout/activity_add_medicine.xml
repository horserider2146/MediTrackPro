<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Back -->
        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:text="← Back"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Medication 💊"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="Fill in your medicine details"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Form Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Medicine Name -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="Medicine Name" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etMedicineName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@null"
                        android:hint="e.g. Metformin"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- Dose -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="Dose" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etDose"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@null"
                        android:hint="e.g. 500mg"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- Times -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="Time(s)" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etTimes"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@null"
                        android:hint="e.g. 08:00, 20:00"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- Refill Days -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="6dp" android:text="Refill in (days)" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>
                <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardBackgroundColor="@color/surface" app:cardCornerRadius="14dp" app:cardElevation="0dp">
                    <EditText
                        android:id="@+id/etRefillDays"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@null"
                        android:hint="e.g. 30"
                        android:inputType="number"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp" />
                </androidx.cardview.widget.CardView>

                <!-- Color picker -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:text="Color Tag" android:textColor="@color/text_secondary" android:textSize="12sp" android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <Button android:id="@+id/btnColorAccent" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:backgroundTint="#00D4AA" android:text="●" android:textColor="@color/bg_dark" android:textSize="18sp"/>
                    <Button android:id="@+id/btnColorBlue" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:backgroundTint="#4A9FFF" android:text="●" android:textColor="@color/bg_dark" android:textSize="18sp"/>
                    <Button android:id="@+id/btnColorPurple" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:backgroundTint="#A78BFA" android:text="●" android:textColor="@color/bg_dark" android:textSize="18sp"/>
                    <Button android:id="@+id/btnColorGold" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="1" android:backgroundTint="#FFB347" android:text="●" android:textColor="@color/bg_dark" android:textSize="18sp"/>

                </LinearLayout>

                <!-- Save Button -->
                <Button
                    android:id="@+id/btnSaveMedicine"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:backgroundTint="@color/accent"
                    android:text="Save Medicine"
                    android:textColor="@color/bg_dark"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>